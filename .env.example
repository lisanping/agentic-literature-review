# ── OpenAI ──
OPENAI_API_KEY=sk-...                           # 必需
OPENAI_MODEL=gpt-4o                             # 默认 gpt-4o

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///data/app.db    # MVP 用 SQLite

# ── Vector database ──
CHROMA_PATH=/data/chroma                        # 向量数据库路径

# ── Redis ──
REDIS_URL=redis://localhost:6379/0              # Redis 连接

# ── Semantic Scholar ──
S2_API_KEY=                                     # Semantic Scholar API Key（可选，提高速率限制）

# ── Logging ──
LOG_LEVEL=INFO

# ── LangGraph Checkpointer ──
CHECKPOINTER_BACKEND=sqlite                     # "sqlite" (MVP) | "postgres" (远期)
CHECKPOINT_DB_URL=sqlite:///data/checkpoints.db

# ── LLM Routing ──
LLM_ROUTING_CONFIG=                             # 可选: LLM 路由配置文件路径

# ── Prompt templates ──
PROMPTS_DIR=prompts                             # Prompt 模板目录
